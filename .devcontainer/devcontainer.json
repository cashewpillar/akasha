// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
	"features": {
		"ghcr.io/devcontainer-config/features/dot-config:4": {}
	},

	// This maps node_modules to a Docker Volume instead of your host disk.
    // It prevents malicious scripts from writing persistent files to your computer.
    "mounts": [
        "source=${localWorkspaceFolderBasename}-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
    ],

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "yarn install",

	// Configure tool-specific properties.
	// "customizations": {},

	// Disable Post-Install Scripts: This is the most common way malicious packages execute code. You can tell npm to ignore them by default within the container environment.
	"containerEnv": {
		"npm_config_ignore_scripts": "true"
	},

	// Avoid Root: Ensure the container runs as a non-root user (usually node or vscode).
	"remoteUser": "node"
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
